# Kopiera till .env och fyll i
# Backend: OpenRouter (pydantic-ai har inbyggt stöd för "openrouter:<model>")
# Dubbelkolla modellens exakta slug på https://openrouter.ai/models innan första körning.
OPENROUTER_API_KEY=sk-or-...
VARV_AGENT_MODEL=openrouter:anthropic/claude-sonnet-5
VARV_DATABASE_URL=sqlite:///./varv.db
# Lokal inferens via LM Studio istället:
# VARV_AGENT_MODEL=openai:qwen3-35b
# OPENAI_BASE_URL=http://192.168.1.50:1234/v1
# OPENAI_API_KEY=lm-studio
VARV_WHISPER_MODEL=KBLab/kb-whisper-tiny
VARV_WHISPER_COMPUTE_TYPE=int8
VARV_OPENAI_API_KEY=
# Web-transkribering via OpenAI Whisper API (fortare än lokal modell)

# Google-koppling (kalender + gmail → fångst, en gång i timmen). En OAuth-app delad av alla
# användare — varje person kopplar sitt EGET Google-konto via Inställningar → Kopplingar.
# Skapa OAuth-klienten i Google Cloud Console (Calendar + Gmail read-only scopes). Ingen
# redirect-URI här — den räknas ut dynamiskt från requesten (samma host/port besökaren
# faktiskt använder), men den exakta URI:n (t.ex. http://192.168.0.121:8420/api/integrations/
# google/callback) måste ändå registreras som "Authorized redirect URI" i Cloud Console.
VARV_GOOGLE_CLIENT_ID=
VARV_GOOGLE_CLIENT_SECRET=
