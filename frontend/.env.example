# Kopiera till .env (lokal dev) eller sätt som Environment Variables i Render.
# TUNNEL_ADDRESS = adressen till tunneln in till varv-server på Raspberry Pi:n
# (t.ex. en Cloudflare/Tailscale-tunnel), inte en riktig domän.
# Inloggning (användarnamn/lösenord) sker i appen, inte via miljövariabel.
VITE_API_BASE_URL=https://TUNNEL_ADDRESS
